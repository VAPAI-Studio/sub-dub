# Hugging Face Token (required for speaker diarization)
HF_TOKEN=your_huggingface_token_here

# Anthropic API Key (required for translation with Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ElevenLabs API Key (required for text-to-speech dubbing)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Supabase Configuration (required for project persistence)
# For local development with Supabase CLI: http://127.0.0.1:54321
# For production: https://your-project.supabase.co
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=your_supabase_anon_or_service_key_here
